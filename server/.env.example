PORT=5050
NODE_ENV=production

# Required: 32+ random chars. e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# MongoDB connection string. Replica set required for change streams.
MONGO_URI=mongodb+srv://DB_USER:DB_PASS@cluster0.xxxxx.mongodb.net/cyber_panel?retryWrites=true&w=majority&appName=Cluster0

# CORS — comma-separated explicit origins. Never `*` in production.
CORS_ORIGIN=https://sanjhi-am-glow.netlify.app

# Default tenant admin (created on first boot).
ADMIN_EMAIL=admin@cyberpanel.local
ADMIN_PASSWORD=change_this_password

# Optional: superadmin who can manage all tenants via /api/admin.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Login lockout policy.
AUTH_MAX_FAILED=5
AUTH_LOCK_MINUTES=15
